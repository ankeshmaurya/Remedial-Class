# Flask Configuration
SECRET_KEY=your-super-secret-key-change-in-production
FLASK_ENV=development

# Database
DATABASE_URL=sqlite:///makeup_classes.db

# Mail Configuration (configure for your email provider)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@makeupclass.edu

# Application Settings
APP_NAME=Make-Up Class Module
ADMIN_EMAIL=admin@makeupclass.edu
